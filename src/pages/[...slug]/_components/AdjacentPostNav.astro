---
import IconArrowLeft from "@/assets/icons/IconArrowLeft.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { useTranslations } from "@/i18n";
import { getPostUrl } from "@/utils/getPostPaths";
import config from "@/config";

type AdjacentPost = {
  id: string;
  title: string;
  slug?: string | null;
  filePath: string | undefined;
} | null;

type Props = {
  prevPost: AdjacentPost;
  nextPost: AdjacentPost;
};

const { prevPost, nextPost } = Astro.props;
const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);
---

<div
  data-pagefind-ignore
  class="my-8 grid grid-cols-1 gap-8 py-1 sm:grid-cols-2"
>
  {
    prevPost && (
      <a
        href={getPostUrl(prevPost.id, prevPost.filePath, locale, prevPost.slug)}
        class="group flex w-full items-start gap-3"
      >
        <IconArrowLeft class="mt-0.5 inline-block size-5 flex-none rtl:rotate-180" />
        <div class="flex min-w-0 flex-col gap-1.5">
          <span class="text-muted-foreground text-xs font-medium tracking-[0.12em] uppercase">
            {t.post.previousPost}
          </span>
          <div class="font-prose text-accent text-base leading-snug font-semibold tracking-tight decoration-dashed underline-offset-4 group-hover:underline">
            {prevPost.title}
          </div>
        </div>
      </a>
    )
  }
  {
    nextPost && (
      <a
        href={getPostUrl(nextPost.id, nextPost.filePath, locale, nextPost.slug)}
        class="group flex w-full items-start justify-end gap-3 text-end sm:col-start-2"
      >
        <div class="flex min-w-0 flex-col items-end gap-1.5">
          <span class="text-muted-foreground text-xs font-medium tracking-[0.12em] uppercase">
            {t.post.nextPost}
          </span>
          <div class="font-prose text-accent text-base leading-snug font-semibold tracking-tight decoration-dashed underline-offset-4 group-hover:underline">
            {nextPost.title}
          </div>
        </div>
        <IconArrowRight class="mt-0.5 inline-block size-5 flex-none rtl:rotate-180" />
      </a>
    )
  }
</div>
