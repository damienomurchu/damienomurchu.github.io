---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import Tag from "@/components/Tag.astro";
import { getUniqueTags } from "@/utils/getUniqueTags";
import { postFilter } from "@/utils/postFilter";
import { useTranslations } from "@/i18n";
import config from "@/config";

const posts = await getCollection("posts", postFilter);
const tags = getUniqueTags(posts).filter(
  ({ postCount }) => postCount >= config.tags.minimumPosts
);

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);
---

<Layout title={`${t.pages.tagsTitle} | ${config.site.title}`}>
  <Header />

  <Breadcrumb />

  <Main pageTitle={t.pages.tagsTitle} pageDesc={t.pages.tagsDesc}>
    <ul class="grid max-w-3xl grid-cols-1 gap-3 sm:grid-cols-2">
      {
        tags.map(({ tag, tagName, postCount }) => (
          <Tag {tag} {tagName} {postCount} variant="directory" />
        ))
      }
    </ul>
  </Main>

  <Footer />
</Layout>
